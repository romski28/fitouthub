  @@index([priority])
  @@index([actionType])
  @@index([assignedToAdminId])
}

model AdminNextStepTemplate {
  id               String   @id @default(cuid())
  projectStage     ProjectStage
  actionType       AdminActionType
  description      String
  triggerCondition String?  // e.g., 'PAYMENT_OVER_10000', 'ON_DISPUTE', 'ALWAYS'
  isPriority       Boolean  @default(false)
  displayOrder     Int      @default(0)
  createdAt        DateTime @default(now())

  @@unique([projectStage, actionType])
  @@index([projectStage])
}

model Policy {
  id          String     @id @default(cuid())
  type        PolicyType
  version     String
  title       String
  content     String     @db.Text
  isActive    Boolean    @default(false)
  createdBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([type, version])
}

// Platform Fee Policy Tables - Phase A
model PlatformFeeQuoteBand {
  id            String   @id @default(cuid())
  minAmount     Decimal  @db.Decimal(12, 2)
  maxAmount     Decimal? @db.Decimal(12, 2)  // NULL means unlimited upper bound
  basePercent   Decimal  @db.Decimal(5, 2)
  effectiveFrom DateTime @default(now())
  effectiveTo   DateTime?
  active        Boolean  @default(true)
  version       Int      @default(1)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([active, effectiveFrom])
}

model PlatformFeePerformanceAdjustment {
  id                String   @id @default(cuid())
  minProjects       Int
  maxProjects       Int?    // NULL means no upper bound
  percentAdjustment Decimal @db.Decimal(5, 2)
  effectiveFrom     DateTime @default(now())
  effectiveTo       DateTime?
  active            Boolean  @default(true)
  version           Int      @default(1)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([active, effectiveFrom])
}

model PlatformFeeLoyaltyAdjustment {
  id                String   @id @default(cuid())
  minProjects       Int
  maxProjects       Int?    // NULL means no upper bound
  percentAdjustment Decimal @db.Decimal(5, 2)
  effectiveFrom     DateTime @default(now())
  effectiveTo       DateTime?
  active            Boolean  @default(true)
  version           Int      @default(1)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([active, effectiveFrom])
}

model AnnouncementTicker {
  id        String   @id @default(cuid())
  title     String?
  content   String   @db.Text
  isActive  Boolean  @default(false)
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([createdAt])
}

model AdminMessageAssignment {
  id                 String   @id @default(cuid())
  sourceType         String
  sourceId           String
  claimedByAdminId   String?
  assignedToAdminId  String?
  status             String   @default("unassigned") // unassigned | claimed | assigned
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  claimedByAdmin     User?    @relation("AdminMessageClaimedBy", fields: [claimedByAdminId], references: [id], onDelete: SetNull)
  assignedToAdmin    User?    @relation("AdminMessageAssignedTo", fields: [assignedToAdminId], references: [id], onDelete: SetNull)

  @@unique([sourceType, sourceId])
  @@index([claimedByAdminId])
  @@index([assignedToAdminId])
  @@index([status])
}

// ── Support Request Pool ─────────────────────────────────────────────────────

enum SupportRequestStatus {
  unassigned
  claimed
  in_progress
  closure_pending
  resolved
}

enum SupportRequestChannel {
  whatsapp
  callback
}

model SupportRequest {
  id               String                @id @default(cuid())
  channel          SupportRequestChannel
  fromNumber       String?               // phone number for whatsapp; empty for callback
  clientName       String?               // WhatsApp profile name or form name
  clientEmail      String?               // from callback form
  body             String                // first message text or callback notes
  twilioMessageSid String?               // Twilio SID for the inbound message
  status           SupportRequestStatus  @default(unassigned)
  assignedAdminId  String?
  claimedAt        DateTime?
  closureRequestedAt DateTime?
  closureDueAt     DateTime?
  resolvedAt       DateTime?
  resolvedBy       String?
  resolutionReason String?
  resolutionMode   String?
  reopenedAt       DateTime?
  projectId        String?               // optional link to a project
  notes            String?               // internal admin notes
  replies          Json[]                // array of {body, sentAt, adminId, direction}
  statusTimeline   Json?                 @default("[]")
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  assignedAdmin    User?    @relation("SupportRequestAdmin", fields: [assignedAdminId], references: [id], onDelete: SetNull)
  project          Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([assignedAdminId])
  @@index([channel])
  @@index([createdAt])
}

  model AiIntake {
    id                String    @id @default(cuid())
    createdAt         DateTime  @default(now())
    userId            String?
    user              User?     @relation(fields: [userId], references: [id])
    sessionId         String?
    rawPrompt         String
    requestId         String    @unique
    model             String?
    durationMs        Int?
    promptTokens      Int?
    completionTokens  Int?
    title             String?
    intent            String?
    trades            String[]
    locationPrimary   String?
    locationSecondary String?
    locationTertiary  String?
    summary           String?
    scope             String?
    risks             Json?
    assumptions       Json?
    nextQuestions     Json?
    project           Json?
    budget            Json?
    timeline          Json?
    overallConfidence Float?
    rawOutput         Json?
    status            String    @default("draft")
    projectId         String?   @unique
    convertedProject  Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

    @@index([userId])
    @@index([sessionId])
    @@index([status])
    @@index([createdAt])
    @@index([projectId])
    @@map("ai_intakes")
  }

// ============================================================
// Case Management
// ============================================================

model Case {
  id              String    @id @default(cuid())
  caseNumber      String    @unique // FOH-YYYY-NNNNN
  title           String?
  category        String    @default("general") // payment | delay | quality | safety | dispute | general
  status          String    @default("open")     // open | awaiting_client | in_progress | resolved | closed
  priority        String    @default("normal")   // low | normal | high | urgent
  raisedBy        String    @default("client")   // client | professional | foh

  projectId       String?
  clientUserId    String?
  professionalId  String?   // professional who raised or is subject
  assignedAdminId String?

  // binds to exactly one thread source
  assistRequestId String?   @unique
  privateChatId   String?   @unique
  supportRequestId String?  @unique

  // SLA
  slaDeadline     DateTime  // createdAt + 1 hour
  firstRepliedAt  DateTime?
  slaBreachedAt   DateTime?
  resolvedAt      DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  notes           CaseNote[]
  assistRequests  ProjectAssistRequest[]

  @@index([status])
  @@index([projectId])
  @@index([clientUserId])
  @@index([professionalId])
  @@index([assignedAdminId])
  @@index([slaDeadline])
  @@index([createdAt])
  @@index([category])
}

model CaseNote {
  id        String   @id @default(cuid())
  caseId    String
  adminId   String
  content   String
  createdAt DateTime @default(now())
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([adminId])
}
