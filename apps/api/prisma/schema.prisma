// Notification System Models
enum NotificationChannel {
  SMS
  WHATSAPP
  WECHAT
  EMAIL
}

enum NotificationStatus {
  pending
  sent
  delivered
  read
  failed
  undeliverable
}

model NotificationPreference {
  id                   String               @id @default(cuid())
  userId               String?
  professionalId       String?
  primaryChannel       NotificationChannel  @default(WHATSAPP)
  fallbackChannel      NotificationChannel  @default(SMS)
  enableSMS            Boolean              @default(true)
  enableWhatsApp       Boolean              @default(true)
  enableWeChat         Boolean              @default(false)
  enableEmail          Boolean              @default(true)
  preferredLanguage    String               @default("en")
  allowPartnerOffers   Boolean              @default(false)
  allowPlatformUpdates Boolean              @default(true)
  weChatOpenId         String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  user                 User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  professional         Professional?        @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@unique([professionalId])
  @@index([userId])
  @@index([professionalId])
}

model NotificationLog {
  id                   String               @id @default(cuid())
  userId               String?
  professionalId       String?
  channel              NotificationChannel
  phoneNumber          String?
  eventType            String               // e.g., "site_access_approved", "quote_awarded"
  message              String
  status               NotificationStatus   @default(pending)
  providerId           String?              // Twilio SID, WeChat msgid, etc.
  providerResponse     Json?
  deliveredAt          DateTime?
  readAt               DateTime?
  failureReason        String?
  retryCount           Int                  @default(0)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  user                 User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  professional         Professional?        @relation(fields: [professionalId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([professionalId])
  @@index([status])
  @@index([eventType])
  @@index([createdAt(sort: Desc)])
}

model NextStepConfig {
  id                       String   @id @default(cuid())
