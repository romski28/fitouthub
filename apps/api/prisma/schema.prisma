generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SiteAccessRequestStatus {
  pending
  approved_no_visit
  approved_visit_scheduled
  visited
  denied
  cancelled
}

enum SiteAccessVisitStatus {
  proposed
  accepted
  declined
  cancelled
  completed
}

enum ProjectStartProposalStatus {
  proposed
  accepted
  declined
  superseded
}

enum LocationDetailsStatus {
  pending
  submitted
  reviewed
  approved
}

enum ProjectStage {
  // Normal project flow (stages 1-16)
  CREATED
  BIDDING_ACTIVE
  SITE_VISIT_SCHEDULED
  SITE_VISIT_COMPLETE
  QUOTE_RECEIVED
  BIDDING_CLOSED
  CONTRACT_PHASE
  PRE_WORK
  WORK_IN_PROGRESS
  MILESTONE_PENDING    // Can repeat for each milestone
  PAYMENT_RELEASED     // Can repeat for each milestone
  NEAR_COMPLETION
  FINAL_INSPECTION
  COMPLETE
  WARRANTY_PERIOD      // Warranty/defect reporting phase
  CLOSED
  // Exceptional states (can occur at any point)
  PAUSED
  DISPUTED
}

enum ProjectScale {
  SCALE_1
  SCALE_2
  SCALE_3
}

enum EscrowFundingPolicy {
  FULL_UPFRONT
  ROLLING_TWO_MILESTONES
}

enum PaymentPlanStatus {
  draft
  client_review
  admin_review
  locked
  active
  completed
  cancelled
}

enum PaymentMilestoneType {
  deposit
  progress
  final
}

enum PaymentMilestoneStatus {
  scheduled
  escrow_requested
  escrow_funded
  release_requested
  released
  disputed
  cancelled
}

enum AdminActionType {
  VERIFY_ESCROW_RECEIPT
  APPROVE_PAYMENT_RELEASE
  REVIEW_CONTRACT
  VALIDATE_INSURANCE
  VALIDATE_LICENSE
  RESOLVE_DISPUTE
  APPROVE_LARGE_BUDGET
  FLAG_QUALITY_ISSUE
  INVESTIGATE_COMPLAINT
  APPROVE_CHANGE_ORDER
}

enum PolicyType {
  TERMS_AND_CONDITIONS
  SECURITY_STATEMENT
  CONTRACT_TEMPLATE
}

enum QuestionnaireStatus {
  draft
  active
  archived
}

enum QuestionnaireQuestionType {
  short_text
  long_text
  single_select
  multi_select
  matrix_rating
  yes_no
  number
  email
  phone
  date
}

enum QuestionnaireInviteStatus {
  pending
  opened
  submitted
  expired
  cancelled
}

enum QuestionnaireSubmissionStatus {
  in_progress
  completed
  abandoned
}

model User {
  id                              String                   @id @default(cuid())
  nickname                        String                   @unique
  firstName                       String
  surname                         String
  chineseName                     String?
  email                           String                   @unique
  mobile                          String?
  passwordHash                    String
  passwordResetToken              String?
  passwordResetExpiry             DateTime?
  emailVerified                   Boolean                  @default(false)
  verificationToken               String?
  role                            String                   @default("client")
  createdAt                       DateTime                 @default(now())
  updatedAt                       DateTime                 @updatedAt
  professional                    Professional?
  projects                        Project[]
  assistRequests                  ProjectAssistRequest[]   @relation("UserAssistRequests")
  privateChatThreads              PrivateChatThread[]
  privateChatMessagesSent         PrivateChatMessage[]     @relation("UserSender")
  activityLogs                    ActivityLog[]
  siteAccessDataSubmitted         SiteAccessData[]
  siteAccessDataUpdated           SiteAccessData[]         @relation("SiteAccessDataUpdatedBy")
  siteAccessRequestsApproved      SiteAccessRequest[]
  siteAccessVisitResponses        SiteAccessVisit[]    @relation("SiteAccessVisitRespondedBy")
  projectLocationDetailsSubmitted ProjectLocationDetails[]
  projectLocationDetailsReviewed  ProjectLocationDetails[] @relation("ProjectLocationDetailsReviewedBy")
  notificationPreference          NotificationPreference?
  notificationLogs                NotificationLog[]
  nextStepActions                 NextStepAction[]
  adminActionsAssigned            AdminAction[]           @relation("AdminActionAssigned")
  adminActionsCompleted           AdminAction[]           @relation("AdminActionCompleted")
  contractsSignedAsClient         Project[]               @relation("ClientContractSignature")
  otpCode                         String?
  otpExpiresAt                    DateTime?
  otpVerifiedAt                   DateTime?
  sessionToken                    String?
  contractsSignedAsProfessional   Project[]               @relation("ProfessionalContractSignature")
  agreedToTermsAt                DateTime?
  agreedToTermsVersion            String?                 @default("1.0")
  agreedToSecurityStatementAt     DateTime?
  agreedToSecurityStatementVersion String?                @default("1.0")
  supportRequests                 SupportRequest[]        @relation("SupportRequestAdmin")
  aiIntakes                       AiIntake[]
  claimedAdminMessages            AdminMessageAssignment[] @relation("AdminMessageClaimedBy")
  assignedAdminMessages           AdminMessageAssignment[] @relation("AdminMessageAssignedTo")
  escrowCheckoutOtpChallenges     EscrowCheckoutOtpChallenge[]
  acProjects                      AcProject[]
}

model Tradesman {
  id              String           @id @default(cuid())
  title           String           @unique
  category        String
  emoji           String?
  description     String?
  featured        Boolean          @default(false)
  image           String?
  jobs            String[]
  aliases         String[]         @default([])
  professionType  String?
  enabled         Boolean          @default(true)
  usageCount      Int              @default(0)
  sortOrder       Int              @default(999)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  serviceMappings ServiceMapping[]
  milestoneTemplates MilestoneTemplate[]
  translations    TradesmanTranslation[]

  @@index([category])
  @@index([enabled])
  @@index([professionType])
}

model TradesmanTranslation {
  id          String    @id @default(cuid())
  tradeId     String
  locale      String
  title       String
  description String?
  jobs        String[]  @default([])
  aliases     String[]  @default([])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  trade       Tradesman @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@unique([tradeId, locale])
  @@index([locale])
  @@index([tradeId])
}

model MilestoneTemplate {
  id                     String   @id @default(cuid())
  tradeId                String
  stageName              String
  sequence               Int
  description            String?
  estimatedDurationDays  Int?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  
  trade                  Tradesman @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  projectMilestones      ProjectMilestone[] @relation("TemplateToMilestone")

  @@index([tradeId])
  @@unique([tradeId, sequence])
}

model Professional {
  id                      String                         @id @default(cuid())
  userId                  String?                        @unique
  status                  String                         @default("pending")
  rating                  Float                          @default(0)
  registrationDate        DateTime                       @default(now())
  fullName                String?
  businessName            String?
  serviceArea             String?
  createdAt               DateTime                       @default(now())
  updatedAt               DateTime                       @updatedAt
  email                   String                         @unique
  phone                   String
  professionType          String
  additionalData          Json?
  locationPrimary         String?
  locationSecondary       String?
  locationTertiary        String?
  servicePrimaries        String[]                       @default([])
  serviceSecondaries      String[]                       @default([])
  primaryTrade            String?
  profileImages           String[]                       @default([])
  suppliesOffered         String[]                       @default([])
  tradesOffered           String[]                       @default([])
  emergencyCalloutAvailable Boolean                      @default(false)
  passwordHash            String?
  emailTokens             EmailToken[]
  user                    User?                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectProfessionals    ProjectProfessional[]
  reports                 ProfessionalReport[]
  referenceProjects       ProfessionalReferenceProject[]
  privateChatThreads      PrivateChatThread[]
  privateChatMessagesSent PrivateChatMessage[]           @relation("ProfessionalSender")
  activityLogs            ActivityLog[]
  siteAccessRequests      SiteAccessRequest[]
  siteAccessVisits        SiteAccessVisit[]
  startProposals          ProjectStartProposal[]
  notificationLogs        NotificationLog[]
  notificationPreferences NotificationPreference?
  nextStepActions         NextStepAction[]
  agreedToTermsAt                DateTime?
  agreedToTermsVersion            String?                 @default("1.0")
  agreedToSecurityStatementAt     DateTime?
  agreedToSecurityStatementVersion String?                @default("1.0")
  otpCode                 String?
  otpExpiresAt            DateTime?
  otpVerifiedAt           DateTime?
  sessionToken            String?
  regionCoverage          ProfessionalRegionCoverage[]
  acProjects              AcProject[]
}

model RegionZone {
  id         String                       @id @default(cuid())
  code       String                       @unique
  label      String
  labelZh    String?
  sortOrder  Int                          @default(0)
  mapSvgId   String?                      @unique
  createdAt  DateTime                     @default(now())
  updatedAt  DateTime                     @updatedAt
  areas      RegionArea[]
  coverage   ProfessionalRegionCoverage[]

  @@index([sortOrder])
}

model RegionArea {
  id         String                       @id @default(cuid())
  zoneId     String
  code       String                       @unique
  name       String
  nameZh     String?
  sortOrder  Int                          @default(0)
  createdAt  DateTime                     @default(now())
  updatedAt  DateTime                     @updatedAt
  zone       RegionZone                   @relation(fields: [zoneId], references: [id], onDelete: Restrict)
  aliases    RegionAreaAlias[]
  coverage   ProfessionalRegionCoverage[]

  @@unique([zoneId, name])
  @@index([zoneId, sortOrder])
}

model RegionAreaAlias {
  id              String     @id @default(cuid())
  areaId          String
  alias           String
  aliasNormalized String
  createdAt       DateTime   @default(now())
  area            RegionArea @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@unique([areaId, aliasNormalized])
  @@index([aliasNormalized])
}

model ProfessionalRegionCoverage {
  id             String       @id @default(cuid())
  professionalId String
  zoneId         String
  areaId         String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  zone           RegionZone   @relation(fields: [zoneId], references: [id], onDelete: Restrict)
  area           RegionArea?  @relation(fields: [areaId], references: [id], onDelete: SetNull)

  @@index([professionalId])
  @@index([zoneId])
  @@index([areaId])
  @@unique([professionalId, zoneId, areaId])
}

model Project {
  id                           String                  @id @default(cuid())
  status                       String                  @default("pending")
  clientId                     String?
  createdAt                    DateTime                @default(now())
  updatedAt                    DateTime                @updatedAt
  userId                       String?
  budget                       Decimal?                @db.Decimal(12, 2)
  approvedBudget               Decimal?                @db.Decimal(12, 2)
  approvedBudgetTxId           String?                 @unique
  awardedProjectProfessionalId String?                 @unique
  paymentCurrency              String                  @default("HKD")
  escrowRequired               Decimal?                @db.Decimal(12, 2)
  escrowHeld                   Decimal                 @default(0) @db.Decimal(12, 2)
  escrowHeldUpdatedAt          DateTime?
  projectScale                 ProjectScale?
  escrowFundingPolicy          EscrowFundingPolicy?
  paymentPlanLockedAt          DateTime?
  clientName                   String
  contractorName               String?
  notes                        String?
  projectName                  String
  tradesRequired               String[]                @default([])
  servicesUsed                 String[]                @default([])
  region                       String
  startDate                    DateTime?
  endDate                      DateTime?
  siteInspectionAvailableOn    DateTime?
  isEmergency                  Boolean                 @default(false)
  onlySelectedProfessionalsCanBid Boolean              @default(true)
  contractorContactName        String?
  contractorContactPhone       String?
  contractorContactEmail       String?
  siteAccessDataCollected      Boolean                 @default(false)
  siteAccessDataCollectedAt    DateTime?
  locationDetailsStatus        LocationDetailsStatus?  @default(pending)
  locationDetailsRequiredAt    DateTime?
  locationDetailsProvidedAt    DateTime?
  userPrompt                   String?                 // Original natural language prompt from user search/creation for AI training
  aiIntakeId                   String?                 // Link to AI intake that generated this project
  emailTokens                  EmailToken[]
  user                         User?                   @relation(fields: [userId], references: [id])
  photos                       ProjectPhoto[]
  professionals                ProjectProfessional[]
  assistRequests               ProjectAssistRequest[]
  chatThread                   ProjectChatThread?
  financialTransactions        FinancialTransaction[]
  escrowLedgers                EscrowLedger[]
  procurementEvidence          MilestoneProcurementEvidence[]
  approvedBudgetTransaction    FinancialTransaction?   @relation("ApprovedBudgetTx", fields: [approvedBudgetTxId], references: [id])
  awardedProjectProfessional   ProjectProfessional?    @relation("AwardedProjectProfessional", fields: [awardedProjectProfessionalId], references: [id])
  aiIntake                     AiIntake?
  siteAccessRequests           SiteAccessRequest[]
  siteAccessVisits             SiteAccessVisit[]
  startProposals               ProjectStartProposal[]
  siteAccessData               SiteAccessData?
  locationDetails              ProjectLocationDetails?
  milestones                   ProjectMilestone[]
  currentStage                 ProjectStage             @default(CREATED)
  stageStartedAt               DateTime                 @default(now())
  lastStageTransitionAt        DateTime?                @updatedAt
  nextStepActions              NextStepAction[]
  adminActions                 AdminAction[]
  // Contract signing fields
  contractType                 String?                  // e.g., 'BASIC', 'STANDARD', 'COMPREHENSIVE'
  contractContent              String?                  @db.Text // Snapshot of contract at signing time
  contractGeneratedAt          DateTime?
  clientSignedAt               DateTime?
  clientSignedById             String?
  clientSignedBy               User?                    @relation("ClientContractSignature", fields: [clientSignedById], references: [id])
  professionalSignedAt         DateTime?
  professionalSignedById       String?
  professionalSignedBy         User?                    @relation("ProfessionalContractSignature", fields: [professionalSignedById], references: [id])
  supportRequests              SupportRequest[]
  paymentPlan                  ProjectPaymentPlan?
  acProjects                   AcProject[]
}

model AcProject {
  id                  String       @id @default(cuid())
  userId              String?
  professionalId      String?
  linkedProjectId     String?
  title               String
  notes               String?
  calculationMethod   String       @default("area")
  combineRooms        Boolean      @default(false)
  totalBtu            Int?
  recommendedSystem   String?
  compressorSuggestion String?
  shoppingList        Json?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  user                User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  professional        Professional? @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  linkedProject       Project?     @relation(fields: [linkedProjectId], references: [id], onDelete: SetNull)
  rooms               AcRoom[]

  @@index([userId])
  @@index([professionalId])
  @@index([linkedProjectId])
  @@index([updatedAt])
}

model AcRoom {
  id                String    @id @default(cuid())
  acProjectId       String
  name              String
  lengthMeters      Decimal   @db.Decimal(8, 2)
  widthMeters       Decimal   @db.Decimal(8, 2)
  heightMeters      Decimal   @db.Decimal(8, 2)
  heatProfile       String    @default("warm")
  occupants         Int       @default(1)
  floor             Int?
  westFacing        Boolean   @default(false)
  largeWindows      Boolean   @default(false)
  calculatedArea    Decimal?  @db.Decimal(10, 2)
  calculatedVolume  Decimal?  @db.Decimal(10, 2)
  calculatedBtu     Int?
  suggestedUnitSize Int?
  recommendedAcType String?
  notes             Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  acProject         AcProject @relation(fields: [acProjectId], references: [id], onDelete: Cascade)

  @@index([acProjectId])
}

model ProjectPhoto {
  id        String   @id @default(cuid())
  projectId String
  url       String
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectProfessional {
  id                      String                 @id @default(cuid())
  projectId               String
  professionalId          String
  status                  String                 @default("pending")
  respondedAt             DateTime?
  quoteAmount             Decimal?               @db.Decimal(12, 2)
  quoteBaseAmount         Decimal?               @db.Decimal(12, 2)
  quotePlatformFeeAmount  Decimal?               @db.Decimal(12, 2) @default(0)
  quotePlatformFeePercent Decimal?               @db.Decimal(5, 2) @default(0)
  quotePricingVersion     String?                @default("unknown")
  quotePlatformFeeBreakdown Json?
  feeCalculatedAt         DateTime?
  quoteNotes              String?
  quoteEstimatedStartAt   DateTime?
  quoteEstimatedDurationMinutes Int?
  quoteEstimatedDurationUnit String @default("hours")
  quotedAt                DateTime?
  directContactShared     Boolean                @default(false)
  directContactSharedAt   DateTime?
  quoteReminderSentAt     DateTime?
  quoteExtendedUntil      DateTime?
  visitApprovedButNotDone Boolean                @default(false)
  siteVisitedAt           DateTime?
  visitNotes              String?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  professional            Professional           @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  project                 Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages                Message[]
  paymentRequests         PaymentRequest[]
  financialTransactions   FinancialTransaction[]
  escrowLedgers           EscrowLedger[]
  procurementEvidence     MilestoneProcurementEvidence[]
  awardedInProject        Project?               @relation("AwardedProjectProfessional")
  siteAccessRequests      SiteAccessRequest[]
  siteAccessVisits         SiteAccessVisit[]
  startProposals          ProjectStartProposal[]
  milestones              ProjectMilestone[]
  paymentPlans            ProjectPaymentPlan[]

  @@unique([projectId, professionalId])
  @@index([projectId])
  @@index([professionalId])
}

model ProjectPaymentPlan {
  id                       String              @id @default(cuid())
  projectId                String              @unique
  projectProfessionalId    String?
  projectScale             ProjectScale
  escrowFundingPolicy      EscrowFundingPolicy
  status                   PaymentPlanStatus   @default(draft)
  currency                 String              @default("HKD")
  totalAmount              Decimal             @db.Decimal(12, 2)
  depositCapPercent        Int?
  fundingBufferMilestones  Int?
  clientComment            String?
  adminComment             String?
  adminOverrideApplied     Boolean             @default(false)
  retentionEnabled         Boolean             @default(false)
  retentionPercent         Decimal?            @db.Decimal(5, 2)
  retentionAmount          Decimal?            @db.Decimal(12, 2)
  retentionReleaseAt       DateTime?
  lockedAt                 DateTime?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  project                  Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectProfessional      ProjectProfessional? @relation(fields: [projectProfessionalId], references: [id], onDelete: SetNull)
  milestones               PaymentMilestone[]

  @@index([projectProfessionalId])
  @@index([status])
}

model PaymentMilestone {
  id                String                @id @default(cuid())
  paymentPlanId     String
  sequence          Int
  title             String
  type              PaymentMilestoneType
  projectMilestoneId String?
  status            PaymentMilestoneStatus @default(scheduled)
  percentOfTotal    Float?
  amount            Decimal               @db.Decimal(12, 2)
  plannedDueAt      DateTime?
  escrowRequestedAt DateTime?
  escrowFundedAt    DateTime?
  releaseRequestedAt DateTime?
  releasedAt        DateTime?
  clientComment     String?
  adminComment      String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  paymentPlan       ProjectPaymentPlan    @relation(fields: [paymentPlanId], references: [id], onDelete: Cascade)
  projectMilestone  ProjectMilestone?     @relation(fields: [projectMilestoneId], references: [id], onDelete: SetNull)
  procurementEvidence MilestoneProcurementEvidence[]

  @@unique([paymentPlanId, sequence])
  @@index([projectMilestoneId])
  @@index([paymentPlanId])
  @@index([status])
}

model MilestoneProcurementEvidence {
  id                      String   @id @default(cuid())
  projectId               String
  paymentMilestoneId      String
  projectProfessionalId   String?
  submittedBy             String
  submittedByRole         String   @default("professional")
  claimedAmount           Decimal  @db.Decimal(12, 2)
  approvedAmount          Decimal? @db.Decimal(12, 2)
  invoiceUrls             String[] @default([])
  photoUrls               String[] @default([])
  openingMessage          String?
  notes                   String?
  status                  String   @default("pending") // pending | approved | rejected
  deadlineAt              DateTime?
  finalizedAt             DateTime?
  clientQuestionedAt      DateTime?
  professionalRespondedAt DateTime?
  reviewedBy              String?
  reviewedByRole          String?
  reviewedAt              DateTime?
  reviewNotes             String?
  titleTransferAcknowledged Boolean @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  project                 Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  paymentMilestone        PaymentMilestone     @relation(fields: [paymentMilestoneId], references: [id], onDelete: Cascade)
  projectProfessional     ProjectProfessional? @relation(fields: [projectProfessionalId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([paymentMilestoneId])
  @@index([projectProfessionalId])
  @@index([status])
  @@index([status, deadlineAt])
}

model ProjectStartProposal {
  id                    String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId             String
  projectProfessionalId String
  professionalId        String
  proposedByRole        String                     @default("professional")
  proposedByUserId      String?
  status                ProjectStartProposalStatus @default(proposed)
  proposedStartAt       DateTime
  durationMinutes       Int
  notes                 String?
  responseNotes         String?
  respondedAt           DateTime?
  respondedBy           String?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  project             Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectProfessional ProjectProfessional @relation(fields: [projectProfessionalId], references: [id], onDelete: Cascade)
  professional        Professional        @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectProfessionalId])
  @@index([professionalId])
  @@index([status])
  @@index([projectId, status])
  @@index([projectId, projectProfessionalId, status, createdAt])
}

model EscrowLedger {
  id                    String   @id @default(uuid()) @db.Uuid
  projectId             String
  projectProfessionalId String?
  transactionId         String?
  direction             String // 'credit' | 'debit'
  amount                Decimal  @db.Decimal(12, 2)
  currency              String   @default("HKD")
  description           String?
  createdAt             DateTime @default(now())
  createdBy             String?
  meta                  Json     @default("{}")

  project             Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectProfessional ProjectProfessional?  @relation(fields: [projectProfessionalId], references: [id], onDelete: SetNull)
  transaction         FinancialTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([projectProfessionalId])
  @@index([transactionId])
}

model ProfessionalReferenceProject {
  id             String   @id @default(uuid()) @db.Uuid
  professionalId String
  title          String
  description    String?
  imageUrls      String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId])
}

model ProjectMilestone {
  id                    String   @id @default(cuid())
  projectId             String
  projectProfessionalId String?
  templateId            String?
  title                 String
  sequence              Int
  isFinancial           Boolean  @default(false)
  status                String   @default("not_started") // not_started | in_progress | completed
  percentComplete       Int      @default(0)
  plannedStartDate      DateTime?
  plannedEndDate        DateTime?
  actualEndDate         DateTime?
  startTimeSlot         String?  // "AM" | "PM" | "ALL_DAY"
  endTimeSlot           String?  // "AM" | "PM" | "ALL_DAY"
  estimatedHours        Int?
  siteAccessRequired    Boolean  @default(true)
  siteAccessNotes       String?
  accessDeclined        Boolean  @default(false)
  accessDeclinedReason  String?
  accessDeclinedAt      DateTime?
  accessDeclinedByClientId String?
  description           String?
  photoUrls             String[] @default([])
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  project                 Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectProfessional     ProjectProfessional? @relation(fields: [projectProfessionalId], references: [id], onDelete: SetNull)
  milestoneTemplate       MilestoneTemplate?   @relation("TemplateToMilestone", fields: [templateId], references: [id], onDelete: SetNull)
  paymentMilestones       PaymentMilestone[]

  @@index([projectId])
  @@index([projectProfessionalId])
  @@index([templateId])
  @@index([status])
  @@index([plannedStartDate])
  @@unique([projectId, isFinancial, sequence])
}

model ProfessionalReport {
  id             String       @id @default(cuid())
  professionalId String
  reporterUserId String?
  comments       String
  status         String       @default("new") // new | reviewed | resolved
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId])
  @@index([status])
}

model EmailToken {
  id             String       @id @default(cuid())
  token          String       @unique @default(cuid())
  projectId      String
  professionalId String
  action         String
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime     @default(now())
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([projectId])
}

model Questionnaire {
  id              String                  @id @default(cuid())
  slug            String                  @unique
  title           String
  audienceKey     String
  description     String?
  welcomeTitle    String?
  welcomeMessage  String?
  thankYouTitle   String?
  thankYouMessage String?
  joinCtaLabel    String?
  joinCtaUrl      String?
  status          QuestionnaireStatus     @default(draft)
